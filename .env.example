LINGXING_APP_KEY=your_app_key
LINGXING_APP_SECRET=your_app_secret
LINGXING_WEB_ACCOUNT=your_web_account
LINGXING_WEB_PASSWORD=your_web_password
# 敏感发送文案建议放这里（支持 \n 换行）
# IMESSAGE_TEXT=Hello...\\nSecond line...
# 测试阶段可指定 iMessage 用户名列表（逗号/分号/换行分隔）
# IMESSAGE_TEST_USERNAMES=test_user_1,test_user_2
# 指定回执轮询超时秒数（默认 90）
# IMESSAGE_DELIVERY_CHECK_TIMEOUT_SECONDS=180

# 钉钉批次通知配置（可选）
# 配置以下三个后，脚本会在跑完后自动发送批次汇总 Markdown
# DINGTALK_APP_KEY=your_dingtalk_app_key
# DINGTALK_APP_SECRET=your_dingtalk_app_secret
# DINGTALK_ROBOT_CODE=your_dingtalk_robot_code
#
# 通知目标二选一：
# 1) 群聊（推荐）
# DINGTALK_GROUP_CONVERSATION_ID=cidxxxxxx
#
# 2) 单聊（按 userId 优先，未配 userId 时按用户名查找）
# DINGTALK_NOTIFY_USER_ID=manager_user_id
# DINGTALK_NOTIFY_USER_NAME=张三
# 兼容旧字段（等价于 DINGTALK_NOTIFY_USER_NAME）
# DINGTALK_NOTIFY_USER=张三
